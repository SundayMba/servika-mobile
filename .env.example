# Servika mobile — environment template. Copy to .env and adjust.
#
# Base URL of the Servika backend API.
# - iOS simulator / web:        http://localhost:5046
# - Android emulator:           http://10.0.2.2:5046
# - Physical device (dev build): http://<your-machine-LAN-IP>:5046  e.g. http://192.168.1.20:5046
EXPO_PUBLIC_API_URL=http://localhost:5046

# Google Maps SDK for Android key (renders the map on Android via react-native-maps).
# Injected into the native build by app.config.js. iOS uses Apple Maps (no key).
# Get one in Google Cloud → enable "Maps SDK for Android" → restrict to the Android
# app (package + signing SHA-1). After changing it, rebuild: npx expo run:android
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
